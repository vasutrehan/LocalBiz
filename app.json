{
  "expo": {
    "name": "LocalBiz",
    "slug": "localbiz",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FF5C35"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.localbiz.app",
      "config": {
        "googleMapsApiKey": "AIzaSyC2FKCr3rzsT1Fu8moAQS9NdVAJf2HU01I"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "LocalBiz uses your location to find nearby businesses.",
        "NSLocationAlwaysUsageDescription": "LocalBiz uses your location to find nearby businesses."
      }
    },
    "android": {
      "package": "com.localbiz.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyC2FKCr3rzsT1Fu8moAQS9NdVAJf2HU01I"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      "expo-location",
      "expo-secure-store"
    ],
    "scheme": "localbiz",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "52006dab-a0ab-443a-b7e9-fd7b713b3926"
      }
    }
  }
}
